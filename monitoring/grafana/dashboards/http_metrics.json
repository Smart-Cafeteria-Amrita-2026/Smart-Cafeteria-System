      "id": 2,
      "title": "HTTP Requests (rate)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by(route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
